#!/usr/bin/env regina
/* bin/lint_citations — verify each koan has a Cowlishaw citation and a Station: directive.
 *
 * Contract: specs/002-m2-walking-skeleton/contracts/lint_citations.md.
 * Citation:   Cowlishaw §<sec>, p. <page>     (anywhere in file)
 *   <sec>     digits, optionally .digits one or more times
 *   <page>    one or more digits
 * Station:    line in the leading comment block matching `Station: <text>`
 *   exactly one such line; <text> non-empty after stripping
 *
 * The path manifest (koans/path_to_enlightenment.rexx) is excluded — it is data, not a koan.
 *
 * Exit 0 if every koan passes both checks; exit 1 on any failure or empty koans/.
 */

listing = '/tmp/lint_citations.'RANDOM(1, 99999)'.'TIME('S')'.list'
ADDRESS SYSTEM 'ls koans 2>/dev/null >' listing

files. = ''
files.0 = 0
DO WHILE LINES(listing) > 0
  name = STRIP(LINEIN(listing))
  IF name = '' THEN ITERATE
  IF RIGHT(name, 5) \= '.rexx' THEN ITERATE
  IF name = 'path_to_enlightenment.rexx' THEN ITERATE
  files.0 = files.0 + 1
  i = files.0
  files.i = 'koans/'name
END
CALL STREAM listing, 'C', 'CLOSE'
ADDRESS SYSTEM 'rm -f' listing

IF files.0 = 0 THEN DO
  SAY 'koans/ is empty -- nothing to lint'
  EXIT 1
END

passed = 0
DO i = 1 TO files.0
  path = files.i

  has_citation = 0
  station_count = 0
  in_leading_block = 1
  lines_seen = 0
  DO WHILE LINES(path) > 0
    line = LINEIN(path)
    lines_seen = lines_seen + 1

    IF check_citation(line) THEN has_citation = 1

    IF in_leading_block THEN DO
      IF lines_seen > 50 THEN in_leading_block = 0
      ELSE IF \is_comment_or_blank(line) THEN in_leading_block = 0
      ELSE IF check_station(line) THEN station_count = station_count + 1
    END
  END
  CALL STREAM path, 'C', 'CLOSE'

  reasons. = ''
  reasons.0 = 0
  IF \has_citation THEN DO
    reasons.0 = reasons.0 + 1
    j = reasons.0
    reasons.j = 'MISSING citation'
  END
  IF station_count = 0 THEN DO
    reasons.0 = reasons.0 + 1
    j = reasons.0
    reasons.j = 'MISSING Station: directive'
  END
  ELSE IF station_count > 1 THEN DO
    reasons.0 = reasons.0 + 1
    j = reasons.0
    reasons.j = 'MULTIPLE Station: directives'
  END

  IF reasons.0 = 0 THEN DO
    SAY '[ ok ]' path
    passed = passed + 1
  END
  ELSE DO
    SAY '[FAIL]' path
    DO j = 1 TO reasons.0
      SAY '  'reasons.j
    END
  END
END

SAY ''
SAY passed'/'files.0 'koans passed lint.'

IF passed = files.0 THEN EXIT 0
EXIT 1

is_comment_or_blank: PROCEDURE
  PARSE ARG line
  s = STRIP(line)
  IF s = '' THEN RETURN 1
  IF LEFT(s, 2) = '/*' THEN RETURN 1
  IF LEFT(s, 1) = '*' THEN RETURN 1
  IF RIGHT(s, 2) = '*/' THEN RETURN 1
  RETURN 0

check_station: PROCEDURE
  /* Leading-comment line strip rule: trim whitespace, then trim any
   * leading run of '*' or '/' or whitespace, then check for "Station: ".
   */
  PARSE ARG line
  s = STRIP(line)
  IF s = '' THEN RETURN 0
  /* Strip comment-prefix characters: leading *, / and spaces. */
  DO WHILE s \= ''
    c = LEFT(s, 1)
    IF c = '*' | c = '/' | c = ' ' | c = '09'x THEN s = SUBSTR(s, 2)
    ELSE LEAVE
  END
  IF POS('Station:', s) \= 1 THEN RETURN 0
  rest = STRIP(SUBSTR(s, LENGTH('Station:') + 1))
  IF rest = '' THEN RETURN 0
  RETURN 1

check_citation: PROCEDURE
  PARSE ARG line
  marker = 'Cowlishaw §'
  p1 = POS(marker, line)
  IF p1 = 0 THEN RETURN 0
  section_start = p1 + LENGTH(marker)

  p2 = POS(', p. ', line, section_start)
  IF p2 = 0 THEN RETURN 0
  section = SUBSTR(line, section_start, p2 - section_start)
  IF \is_section(section) THEN RETURN 0

  page_start = p2 + 5
  digits = 0
  DO j = page_start TO LENGTH(line)
    IF \DATATYPE(SUBSTR(line, j, 1), 'W') THEN LEAVE
    digits = digits + 1
  END
  IF digits = 0 THEN RETURN 0
  RETURN 1

is_section: PROCEDURE
  PARSE ARG s
  IF s = '' THEN RETURN 0
  IF POS('.', s) = 0 THEN RETURN 0
  IF LEFT(s, 1) = '.' | RIGHT(s, 1) = '.' THEN RETURN 0
  IF POS('..', s) > 0 THEN RETURN 0
  IF VERIFY(s, '0123456789.') \= 0 THEN RETURN 0
  RETURN 1
